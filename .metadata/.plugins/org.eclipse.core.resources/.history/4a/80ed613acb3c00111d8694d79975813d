	@Override
	public BookingResponseDto confirmBooking(Integer bookingId) {

		Booking booking = bookingRepo.findById(bookingId).orElse(null);

		if (booking == null) {
			throw new RuntimeException("Booking Not Found");
		}

		if (booking.getBookingStatus().equals("BOOKED")) {
			throw new RuntimeException("Booking Already Confirmed");
		}

		if (booking.getBookingStatus().equals("CANCELLED")) {
			throw new RuntimeException("Cancelled Booking Cannot Be Confirmed");
		}

		if (booking.getBookingStatus().equals("EXPIRED")) {
			throw new RuntimeException("Booking Already Expired");
		}

		if (LocalDateTime.now().isAfter(booking.getLockedUntil())) {

			booking.setBookingStatus("EXPIRED");

			bookingRepo.save(booking);

			eventClient.increaseAvailableTickets(booking.getEventId(), booking.getQuantity());

			throw new RuntimeException("Booking Expired");
		}

		booking.setBookingStatus("BOOKED");

		Booking savedBooking = bookingRepo.save(booking);

		UserDto user = userClient.getUserEntityById(savedBooking.getUserId());

		EventDto event = eventClient.getEventEntityById(savedBooking.getEventId());

		VenueDto venue = venueClient.getById(event.getVenueId());

		BookingResponseDto response = new BookingResponseDto();

		UserDto organizer = userClient.getUserEntityById(event.getOrganizerId());

		response.setBookingId(savedBooking.getBookingId());
		response.setQuantity(savedBooking.getQuantity());
		response.setTotalAmount(savedBooking.getTotalAmount());
		response.setBookingDate(savedBooking.getBookingDate());
		response.setBookingStatus(savedBooking.getBookingStatus());
		response.setLockedUntil(savedBooking.getLockedUntil());

		response.setUser(user);
		response.setEvent(event);
		response.setVenue(venue);
		response.setOrganizer(organizer);

//		NotificationDto notification = new NotificationDto();
//
//		notification.setUserId(savedBooking.getUserId());
//		notification.setMessage("Your booking for " + event.getEventName() + " has been confirmed");
//		notification.setNotificationType("BOOKING_CONFIRMED");
//
//		notificationClient.sendNotification(notification);

		return response;
	}

	@Override
	public Booking cancelBooking(Integer id) {

		Booking booking = bookingRepo.findById(id).orElseThrow(() -> new RuntimeException("Booking Not Found"));

		booking.setBookingStatus("CANCELLED");
		EventDto event = eventClient.getEventEntityById(booking.getEventId());


		eventClient.increaseAvailableTickets(booking.getEventId(), booking.getQuantity());
		NotificationDto notification = new NotificationDto();

		notification.setUserId(booking.getUserId());
		notification.setMessage("Your booking for " + event.getEventName() + " has been cancelled");
		notification.setNotificationType("BOOKING_CANCELLED");

		notificationClient.sendNotification(notification);

		return bookingRepo.save(booking);
	}

	@Override
	public String expireBooking(Integer bookingId) {

		Booking booking = bookingRepo.findById(bookingId).orElse(null);

		if (booking == null) {
			throw new RuntimeException("Booking Not Found");
		}

		if (LocalDateTime.now().isAfter(booking.getLockedUntil()) && booking.getBookingStatus().equals("BLOCKED")) {

			booking.setBookingStatus("EXPIRED");

			bookingRepo.save(booking);

			eventClient.increaseAvailableTickets(booking.getEventId(), booking.getQuantity());

			return "Booking Expired And Tickets Released";
		}

		EventDto event = eventClient.getEventEntityById(booking.getEventId());

		NotificationDto notification = new NotificationDto();

		notification.setUserId(booking.getUserId());
		notification.setMessage("Your booking for " + event.getEventName() + " has expired");
		notification.setNotificationType("BOOKING_EXPIRED");

		notificationClient.sendNotification(notification);

		return "Booking Still Active";
	}

	@Override
	public List<BookingResponseDto> viewAll() {

		List<Booking> bookings = bookingRepo.findAll();

		return bookings.stream().map(this::mapBookingResponse).collect(Collectors.toList());
	}

	@Override
	public BookingResponseDto getById(Integer id) {

		Booking booking = bookingRepo.findById(id).orElse(null);

		return mapBookingResponse(booking);
	}
	

	@Override
	public List<BookingResponseDto> getByUser(Integer userId) {

		List<Booking> bookings = bookingRepo.findByUserId(userId);

		return bookings.stream().map(this::mapBookingResponse).collect(Collectors.toList());
	}

	@Override
	public List<BookingResponseDto> getByEvent(Integer eventId) {

		List<Booking> bookings = bookingRepo.findByEventId(eventId);

		return bookings.stream().map(this::mapBookingResponse).collect(Collectors.toList());
	}

	@Override
	public List<BookingResponseDto> getByStatus(String status) {

		List<Booking> bookings = bookingRepo.findByBookingStatus(status);

		return bookings.stream().map(this::mapBookingResponse).collect(Collectors.toList());
	}

