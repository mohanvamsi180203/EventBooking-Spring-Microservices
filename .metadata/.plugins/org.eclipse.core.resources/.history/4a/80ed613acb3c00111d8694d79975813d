	@Override
	public BookingResponseDto blockTickets(Booking booking) {

	    UserDto user = userClient.getUserEntityById(booking.getUserId());

	    if (user == null) {
	        throw new RuntimeException("User Not Found");
	    }

	    EventDto event = eventClient.getEventEntityById(booking.getEventId());

	    if (event == null) {
	        throw new RuntimeException("Event Not Found");
	    }

	    if (event.getEventType() != null && event.getEventType().equalsIgnoreCase("PRIVATE")) {

	        PrivateAccessDto access = privateAccessClient.getByEventAndUser(
	                booking.getEventId(),
	                booking.getUserId());

	        if (access == null) {
	            throw new RuntimeException("You Are Not Invited To This Private Event");
	        }

	        if (!access.getInvitationStatus().equalsIgnoreCase("ACCEPTED")) {
	            throw new RuntimeException("Please Accept Invitation First");
	        }
	    }

	    if (event.getStatus().equals("CANCELLED")) {
	        throw new RuntimeException("Cannot Book Cancelled Event");
	    }

	    if (event.getStatus().equals("COMPLETED")) {
	        throw new RuntimeException("Cannot Book Completed Event");
	    }

	    if (event.getAvailableTickets() < booking.getQuantity()) {
	        throw new RuntimeException("Not Enough Tickets Available");
	    }

	    if (event.getHasSeats() != null && event.getHasSeats()) {

	        if (booking.getSeatIds() == null || booking.getSeatIds().isEmpty()) {
	            throw new RuntimeException("Please Select Seats");
	        }

	        if (booking.getSeatIds().size() != booking.getQuantity()) {
	            throw new RuntimeException("Seat Count Must Match Quantity");
	        }

	        seatClient.lockSeats(
	                booking.getUserId(),
	                booking.getSeatIds());
	    }

	    Double totalAmount = booking.getQuantity() * event.getTicketPrice();

	    booking.setTotalAmount(totalAmount);
	    booking.setBookingDate(LocalDate.now());
	    booking.setBookingStatus("BLOCKED");
	    booking.setLockedUntil(LocalDateTime.now().plusMinutes(5));

	    eventClient.reduceAvailableTickets(
	            booking.getEventId(),
	            booking.getQuantity());

	    Booking savedBooking = bookingRepo.save(booking);

	    VenueDto venue = venueClient.getById(event.getVenueId());

	    BookingResponseDto response = new BookingResponseDto();
	    UserDto organizer = userClient.getUserEntityById(event.getOrganizerId());

	    response.setBookingId(savedBooking.getBookingId());
	    response.setQuantity(savedBooking.getQuantity());
	    response.setTotalAmount(savedBooking.getTotalAmount());
	    response.setBookingDate(savedBooking.getBookingDate());
	    response.setBookingStatus(savedBooking.getBookingStatus());
	    response.setLockedUntil(savedBooking.getLockedUntil());

	    response.setUser(user);
	    response.setEvent(event);
	    response.setVenue(venue);
	    response.setOrganizer(organizer);

	    return response;
	}
	
