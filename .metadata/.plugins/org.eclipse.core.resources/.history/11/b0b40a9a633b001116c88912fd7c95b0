@RestController
@RequestMapping("/api/event")
public class EventController {

    @Autowired
    private EventService eventService;

    @PostMapping("/save")
    public Event addEvent(@RequestBody Event event) {
        return eventService.addEvent(event);
    }

    @PutMapping("/update/{id}")
    public Event updateEvent(@PathVariable Integer id, @RequestBody Event event) {
        return eventService.updateEvent(id, event);
    }

    @DeleteMapping("/delete/{id}")
    public String deleteEvent(@PathVariable Integer id) {
        return eventService.deleteEvent(id);
    }

    @GetMapping("/view")
    public List<Event> viewAll() {
        return eventService.viewAll();
    }

    @GetMapping("/get/{id}")
    public Event getById(@PathVariable Integer id) {
        return eventService.getById(id);
    }

    @GetMapping("/getByName/{name}")
    public List<Event> getByName(@PathVariable String name) {
        return eventService.getByName(name);
    }

    @GetMapping("/getByCategory/{category}")
    public List<Event> getByCategory(@PathVariable String category) {
        return eventService.getByCategory(category);
    }

    @GetMapping("/getByDate/{date}")
    public List<Event> getByDate(@PathVariable LocalDate date) {
        return eventService.getByDate(date);
    }

    @GetMapping("/getByVenue/{venueId}")
    public List<Event> getByVenue(@PathVariable Integer venueId) {
        return eventService.getByVenue(venueId);
    }

    @GetMapping("/getByOrganizer/{organizerId}")
    public List<Event> getByOrganizer(@PathVariable Integer organizerId) {
        return eventService.getByOrganizer(organizerId);
    }
}