    @Override
    public Event increaseAvailableTickets(Integer id, Integer tickets) {

        Event event = eventRepo.findById(id).orElse(null);

        if(event == null) {
            throw new RuntimeException("Event Not Found");
        }

        event.setAvailableTickets(event.getAvailableTickets() + tickets);

        if(event.getAvailableTickets() > event.getTotalTickets()) {
            event.setAvailableTickets(event.getTotalTickets());
        }

        return eventRepo.save(event);
    }
    
    @Override
    public Event getEventEntityById(Integer id) {

        return eventRepo.findById(id).orElse(null);
    }

    @Override
    public Event reduceAvailableTickets(Integer id, Integer tickets) {

        Event event = eventRepo.findById(id).orElse(null);

        if(event == null) {
            throw new RuntimeException("Event Not Found");
        }

        if(event.getAvailableTickets() < tickets) {
            throw new RuntimeException("Not Enough Tickets Available");
        }

        event.setAvailableTickets(event.getAvailableTickets() - tickets);

        return eventRepo.save(event);
    }
    
  
