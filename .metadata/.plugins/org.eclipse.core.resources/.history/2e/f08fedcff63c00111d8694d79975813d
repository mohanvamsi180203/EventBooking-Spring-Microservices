    @Override
    public Event addEvent(Event event) {
    	
    	
    	
    	UserDto organizer = authClient.getById(event.getOrganizerId());

    	if(organizer == null) {
    	    throw new RuntimeException("Organizer Not Found");
    	}
    	
    	if(organizer.getRole() == null ||
    	        !organizer.getRole().equalsIgnoreCase("ORGANIZER")) {
    	    throw new RuntimeException("Only Organizers Can Create Events");
    	}

    	if(organizer.getOrganizerStatus() == null ||
    	        !organizer.getOrganizerStatus().equalsIgnoreCase("APPROVED")) {
    	    throw new RuntimeException("Organizer Not Approved Yet");
    	}

    	if(!organizer.getRole().equalsIgnoreCase("ORGANIZER")) {
    	    throw new RuntimeException("Only Organizers Can Create Events");
    	}

    	if(!organizer.getOrganizerStatus().equalsIgnoreCase("APPROVED")) {
    	    throw new RuntimeException("Organizer Not Approved Yet");
    	}

        VenueDto venue = venueClient.getById(event.getVenueId());

        if(venue == null) {
            throw new RuntimeException("Venue Not Found");
        }

        if(eventRepo.existsByEventNameAndEventDateAndVenueId(
                event.getEventName(),
                event.getEventDate(),
                event.getVenueId())) {

            throw new RuntimeException("Same Event Already Exists In Same Venue On Same Date");
        }

        if(event.getEndTime().isBefore(event.getStartTime())) {
            throw new RuntimeException("End Time Must Be Greater Than Start Time");
        }

        if(event.getTicketPrice() < 0) {
            throw new RuntimeException("Ticket Price Cannot Be Negative");
        }

        if(event.getTotalTickets() <= 0) {
            throw new RuntimeException("Total Tickets Must Be Greater Than Zero");
        }

        if(event.getAvailableTickets() > event.getTotalTickets()) {
            throw new RuntimeException("Available Tickets Cannot Exceed Total Tickets");
        }

        List<Event> existingEvents =
                eventRepo.findByVenueIdAndEventDate(
                        event.getVenueId(),
                        event.getEventDate());

        for(Event existing : existingEvents) {

            boolean overlap =
                    event.getStartTime().isBefore(existing.getEndTime()) &&
                    event.getEndTime().isAfter(existing.getStartTime());

            if(overlap) {
                throw new RuntimeException("Venue Already Occupied During This Time");
            }
        }

        return eventRepo.save(event);
    }

    @Override
    public Event updateEvent(Integer id, Event event) {

        Event existingEvent = eventRepo.findById(id).orElse(null);

        if(existingEvent != null) {
            existingEvent.setEventName(event.getEventName());
            existingEvent.setCategory(event.getCategory());
            existingEvent.setDescription(event.getDescription());
            existingEvent.setEventDate(event.getEventDate());
            existingEvent.setStartTime(event.getStartTime());
            existingEvent.setEndTime(event.getEndTime());
            existingEvent.setVenueId(event.getVenueId());
            existingEvent.setOrganizerId(event.getOrganizerId());
            existingEvent.setEventType(event.getEventType());
            existingEvent.setTicketPrice(event.getTicketPrice());
            existingEvent.setTotalTickets(event.getTotalTickets());
            existingEvent.setAvailableTickets(event.getAvailableTickets());
            existingEvent.setStatus(event.getStatus());

            return eventRepo.save(existingEvent);
        }

        return null;
    }

    @Override
    public String deleteEvent(Integer id) {

        eventRepo.deleteById(id);

        return "Event Deleted Successfully";
    }

