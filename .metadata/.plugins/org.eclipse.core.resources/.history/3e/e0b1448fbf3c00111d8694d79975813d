package com.seat.service.service;

import java.time.LocalDateTime;
import java.util.List;

import com.seat.service.entity.Seat;

public class Snippet {
	@Service
	                seat.setEventId(request.getEventId());
	                seat.setRowNumber(String.valueOf(rowLetter));
	                seat.setColumnNumber(col);
	                seat.setSeatLabel(rowLetter + String.valueOf(col));
	                seat.setPrice(request.getPrice());
	                seat.setStatus("AVAILABLE");
	
	                seatList.add(seat);
	            }
	        }
	
	        return seatRepo.saveAll(seatList);
	    }
	
	    @Override
	    public List<Seat> getSeatsByEvent(Integer eventId) {
	        return seatRepo.findByEventId(eventId);
	    }
	
	    @Override
	    public List<Seat> lockSeats(Integer userId, List<Integer> seatIds) {
	
	        List<Seat> seats = seatRepo.findAllById(seatIds);
	
	        for(Seat seat : seats) {
	
	            if(!seat.getStatus().equalsIgnoreCase("AVAILABLE")) {
	                throw new RuntimeException(
	                        "Seat Already Locked Or Booked: " + seat.getSeatLabel());
	            }
	
	            seat.setStatus("LOCKED");
	            seat.setLockedBy(userId);
	            seat.setLockedUntil(LocalDateTime.now().plusMinutes(5));
	        }
	
	        return seatRepo.saveAll(seats);
	    }
	
	    @Override
	    public List<Seat> confirmSeats(List<Integer> seatIds) {
	
	        List<Seat> seats = seatRepo.findAllById(seatIds);
	
	        for(Seat seat : seats) {
	            seat.setStatus("BOOKED");
	            seat.setLockedBy(null);
	            seat.setLockedUntil(null);
	        }
	
	        return seatRepo.saveAll(seats);
	    }
	
	    @Override
	    public List<Seat> releaseSeats(List<Integer> seatIds) {
	
	        List<Seat> seats = seatRepo.findAllById(seatIds);
	
	        for(Seat seat : seats) {
	            seat.setStatus("AVAILABLE");
	            seat.setLockedBy(null);
	            seat.setLockedUntil(null);
	        }
	
	        return seatRepo.saveAll(seats);
	    }
	}
}

